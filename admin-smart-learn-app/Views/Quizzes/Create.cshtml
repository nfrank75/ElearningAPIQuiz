@model AdminSmartLearn.Models.QuizCreateDto
@{
    ViewData["Title"] = "Créer un Quiz";
}

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">
          Créer un nouveau quiz
        </h2>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row row-cards">
      <div class="col-12">
        <form asp-action="Create" method="post" class="card">
          <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
              <label class="form-label required" asp-for="Title">Titre</label>
              <div>
                <input type="text" class="form-control" asp-for="Title" required>
                <span asp-validation-for="Title" class="text-danger"></span>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label required" asp-for="LevelId">Niveau</label>
              <div>
                <select asp-for="LevelId" asp-items="ViewBag.Levels" class="form-select" required>
                    <option value="">-- Sélectionner un niveau --</option>
                </select>
                <span asp-validation-for="LevelId" class="text-danger"></span>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label required" asp-for="SubjectId">Matière</label>
              <div>
                <select asp-for="SubjectId" asp-items="ViewBag.Subjects" class="form-select" required>
                    <option value="">-- Sélectionner une matière --</option>
                </select>
                <span asp-validation-for="SubjectId" class="text-danger"></span>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label required" asp-for="DurationMinutes">Durée (en minutes)</label>
              <div>
                <input type="number" class="form-control" asp-for="DurationMinutes" required>
                <span asp-validation-for="DurationMinutes" class="text-danger"></span>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label required" asp-for="Coefficient">Coefficient</label>
              <div>
                <input type="number" step="0.5" class="form-control" asp-for="Coefficient" required>
                <span asp-validation-for="Coefficient" class="text-danger"></span>
              </div>
            </div>
          </div>
          <div class="card-footer text-end">
            <div class="d-flex">
              <a asp-action="Index" class="btn btn-link">Annuler</a>
              <button type="submit" class="btn btn-primary ms-auto">Créer le quiz</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
