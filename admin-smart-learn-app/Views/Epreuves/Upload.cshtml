@model AdminSmartLearn.Models.EpreuveUploadDto
@{
    ViewData["Title"] = "Uploader une Épreuve";
}

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">
          Uploader une Nouvelle Épreuve
        </h2>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row row-cards">
      <div class="col-12">
        <form asp-action="Upload" method="post" enctype="multipart/form-data" class="card">
          <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
              <label class="form-label required" asp-for="Title">Titre</label>
              <div>
                <input type="text" class="form-control" asp-for="Title" required>
              </div>
            </div>
            
            <div class="mb-3">
              <label class="form-label required" asp-for="Year">Année</label>
              <div>
                <input type="number" class="form-control" asp-for="Year" required>
              </div>
            </div>
            
            <div class="mb-3">
              <label class="form-label required" asp-for="LevelId">Niveau</label>
              <div>
                <select asp-for="LevelId" asp-items="ViewBag.Levels" class="form-select" required>
                    <option value="">-- Sélectionner un niveau --</option>
                </select>
              </div>
            </div>
            
            <div class="mb-3">
              <label class="form-label required" asp-for="SubjectId">Matière</label>
              <div>
                <select asp-for="SubjectId" asp-items="ViewBag.Subjects" class="form-select" required>
                    <option value="">-- Sélectionner une matière --</option>
                </select>
              </div>
            </div>
            
            <div class="mb-3">
              <label class="form-check">
                <input type="checkbox" class="form-check-input" asp-for="IsCorrected">
                <span class="form-check-label">Cette épreuve est-elle corrigée ?</span>
              </label>
            </div>
            
            <div class="mb-3">
              <label class="form-label required">Fichier (PDF, Image...)</label>
              <div>
                <input type="file" name="file" class="form-control" required>
              </div>
            </div>
          </div>
          
          <div class="card-footer text-end">
            <div class="d-flex">
              <a asp-action="Index" class="btn btn-link">Annuler</a>
              <button type="submit" class="btn btn-primary ms-auto">Uploader</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
